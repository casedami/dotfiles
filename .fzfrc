--color=fg:#68605F,bg:#171614,hl:#8a879c,gutter:#171614
--color=fg+:#8D978B,bg+:#1F1E1C,hl+:#8a879c
--color=info:#717d6e,prompt:#6E665E,pointer:#808796
--color=marker:#8a7f76,spinner:#8a7f76,header:#8a7f76
--separator="─" --scrollbar="│" --layout="reverse" --info="right"
--prompt="$ "
--marker="*"
--pointer=">"
--cycle
--multi
--height 40%
--preview "cat {} 2> /dev/null"
--preview-window="right:60%:hidden"
--bind="?:toggle-preview"
--bind="ctrl-u:preview-page-up"
--bind="ctrl-d:preview-page-down"
