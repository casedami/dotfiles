# vim: ft=gitconfig

[alias]
    whoami = !git config user.name && git config user.email

[commit]
    template = ~/.config/git/template
    gpgSign = true

[core]
    editor = nvim
    excludesfile = ~/.config/git/ignore

[diff]
    external = difft
    tool = nvim_difftool

[difftool "nvim_difftool"]
    cmd = nvim -c "\"packadd nvim.difftool\"" -c "\"DiffTool $LOCAL $REMOTE\""

[gpg]
    format = ssh

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true
    default = current
    followTags = true

[pull]
    default = current
    rebase = true

[status]
    branch = true
    showStash = true
    showUntrackedFiles = all

[url "git@github.com:casedami/"]
    insteadOf = "cdm:"

[url "git@github.com:"]
    insteadOf = "gh:"

