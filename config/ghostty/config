font-family = "Lilex Nerd Font"
font-size = 11

theme = hojicha
gtk-custom-css = tabbar-style.css
mouse-hide-while-typing = true

window-subtitle = false
command = nu
shell-integration-features = ssh-terminfo,ssh-env

macos-window-shadow = false
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = true
gtk-titlebar = false

keybind = ctrl+a>minus=new_split:down
keybind = ctrl+a>shift+backslash=new_split:right

keybind = ctrl+a>d=close_surface
keybind = ctrl+a>r=reload_config

keybind = ctrl+a>e=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>c=close_tab

keybind = ctrl+a>left=goto_split:left
keybind = ctrl+a>right=goto_split:right
keybind = ctrl+a>up=goto_split:up
keybind = ctrl+a>down=goto_split:down
keybind = shift+enter=text:\x1b\r
keybind = ctrl+enter=unbind
keybind = ctrl+shift+p=unbind
keybind = ctrl+a>r=prompt_tab_title
