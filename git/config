[alias]
    aliases = config --get-regexp alias
    amend = commit --amend --no-edit
    whoami = !git config user.name && git config user.email
    a = add
    aip = add -ip
    b = branch
    c = commit --verbose
    d = diff
    m = merge
    r = rebase
    x = checkout

[commit]
    template = ~/.config/git/template
    gpgSign = true

[core]
    editor = nvim
    excludesfile = ~/.config/git/ignore

[diff]
    external = difft

[pager]
    diff = less -R

[gpg]
    format = ssh

[include]
    path = ~/.config/git/.gitconfig-local

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true
    default = current
    followTags = true

[pull]
    default = current
    rebase = true

[status]
    branch = true
    showStash = true
    showUntrackedFiles = all

[url "git@github.com:casedami/"]
    insteadOf = "cdm:"

[url "git@github.com:"]
    insteadOf = "gh:"

