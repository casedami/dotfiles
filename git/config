[alias]
    aliases = config --get-regexp alias
    amend = commit --amend --no-edit
    whoami = !git config user.name && git config user.email
    a = add
    b = branch
    c = commit --verbose
    d = diff
    dt = difftool -d
    m = merge
    r = rebase
    x = checkout
    wa = worktree add
    wr = worktree remove
    wl = worktree list
    s = !nu --config ~/dotfiles/nushell/config.nu -c git-status-pretty
    l = "!f() { nu --config ~/dotfiles/nushell/config.nu -c \"git-log-pretty $*\"; }; f"
    xc = !nu --config ~/dotfiles/nushell/config.nu -c git-checkout-fzf
    ac = !nu --config ~/dotfiles/nushell/config.nu -c git-add-fzf
    q = !nu --config ~/dotfiles/nushell/config.nu -c git-conflicts

[commit]
    template = ~/.config/git/template
    gpgSign = true

[core]
    editor = nvim
    excludesfile = ~/.config/git/ignore

[diff]
    external = difft
    tool = nvim_difftool

[difftool "nvim_difftool"]
    cmd = nvim -c "\"packadd nvim.difftool\"" -c "\"DiffTool $LOCAL $REMOTE\""

[gpg]
    format = ssh

[include]
    path = ~/.config/git/.gitconfig-local

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true
    default = current
    followTags = true

[pull]
    default = current
    rebase = true

[status]
    branch = true
    showStash = true
    showUntrackedFiles = all

[url "git@github.com:casedami/"]
    insteadOf = "cdm:"

[url "git@github.com:"]
    insteadOf = "gh:"

